{
  "name": "@brillout/json-serializer",
  "version": "0.5.25",
  "description": "Same as JSON but with added support for `Date`, `undefined`, `Map`, `Set`, and more.",
  "repository": "https://github.com/brillout/json-serializer",
  "main": "./index.mjs",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./parse": {
      "import": "./dist/parse.js",
      "types": "./dist/parse.d.ts",
      "default": "./dist/parse.js"
    },
    "./stringify": {
      "import": "./dist/stringify.js",
      "types": "./dist/stringify.d.ts",
      "default": "./dist/stringify.js"
    }
  },
  "scripts": {
    "========= Dev": "",
    "dev": "tsc --watch",
    "========= Build": "",
    "build": "rm -rf dist/ && tsc",
    "========= Test": "",
    "test": "node ./examples && vitest run",
    "========= Build readme.md": "",
    "docs": "mdocs",
    "========= Formatting": "",
    "format": "pnpm run format:biome",
    "format:prettier": "git ls-files | egrep '\\.(json|js|jsx|css|ts|tsx|vue|mjs|cjs)$' | grep --invert-match package.json | xargs pnpm exec prettier --write",
    "format:biome": "biome format --write .",
    "format:check": "biome format . || echo Fix formatting by running: $ pnpm -w run format",
    "========= Reset": "",
    "reset": "git clean -Xdf && pnpm install && pnpm run build",
    "========= Release": "",
    "release": "release-me patch",
    "release:minor": "release-me minor",
    "release:major": "release-me major",
    "release:commit": "release-me commit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.7.2",
    "@brillout/mdocs": "^0.1.30",
    "@brillout/release-me": "^0.4.7",
    "@types/node": "^24.0.10",
    "@types/react": "^18.2.21",
    "lodash.isequal": "^4.5.0",
    "prettier": "^3.2.5",
    "react": "^17.0.2",
    "typescript": "^5.8.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist/",
    "*.d.ts",
    "*.mjs",
    "*.js"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
